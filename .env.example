# PR Review Dashboard — Environment Variables
# Copy to .env and fill in values

# Azure DevOps PAT (required)
AZURE_DEVOPS_PAT=

# Your name in Azure DevOps (matches displayName or uniqueName)
REVIEWER_NAME=FERN

# Repos to poll (comma-separated)
REPOS=purchase,usermgt,coop,backoffice

# Poll interval in minutes
POLL_INTERVAL_MINUTES=10
